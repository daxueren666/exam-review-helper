{
  "skill_name": "exam-review-helper",
  "_setup_notes": {
    "test_files": "evals 4-7 use files in test_data/ (committed to repo, portable). evals 1-3 reference environment-specific E:/sk2/ PDFs——prepare those separately or skip.",
    "negative_evals": "evals 8-9 are should-not-trigger cases——verify the skill is NOT invoked and no Review directory is created.",
    "mixed_format": "eval 7 tests batch extraction of mixed formats (DOCX + MD) in one command.",
    "runner": "Run via `python scripts/run_evals.py --eval-id <id> --eval-dir <output-dir>`. All assertion paths are relative to --eval-dir.",
    "assertion_types": "dir_exists / file_exists / file_contains / file_not_contains / json_field_equals / no_dir_matching"
  },
  "evals": [
    {
      "id": 1,
      "name": "basic-pdf-review",
      "prompt": "帮我复习这本高等数学教材，文件在 E:/sk2/高等数学-第八版-上册.pdf，只需要处理前10页作为测试",
      "expected_output": "生成 Review - 高等数学-第八版-上册/ 目录，包含 extracted_content.md, knowledge.json, Review.html 文件",
      "files": [],
      "assertions": [
        {
          "name": "output_directory_exists",
          "type": "dir_exists",
          "path": "Review - 高等数学-第八版-上册/",
          "env_specific": true
        },
        {
          "name": "markdown_file_created",
          "type": "file_exists",
          "path": "Review - 高等数学-第八版-上册/extracted_content.md",
          "nonempty": true,
          "env_specific": true
        },
        {
          "name": "knowledge_json_created",
          "type": "json_field_equals",
          "path": "Review - 高等数学-第八版-上册/高等数学-第八版-上册_knowledge.json",
          "field": "source",
          "equals": "高等数学-第八版-上册",
          "env_specific": true
        },
        {
          "name": "html_file_created",
          "type": "file_contains",
          "path": "Review - 高等数学-第八版-上册/Review - 高等数学-第八版-上册.html",
          "contains": "MathJax",
          "env_specific": true
        }
      ]
    },
    {
      "id": 2,
      "name": "chapter-detection",
      "prompt": "提取 E:/sk2/高等数学-第八版-上册.pdf 前50页的知识点，重点识别章节结构",
      "expected_output": "识别出章节边界，输出章节列表和每章的知识点数量",
      "files": [],
      "assertions": [
        {
          "name": "output_directory_exists",
          "type": "dir_exists",
          "path": "Review - 高等数学-第八版-上册/",
          "env_specific": true
        },
        {
          "name": "knowledge_json_valid",
          "type": "file_exists",
          "path": "Review - 高等数学-第八版-上册/高等数学-第八版-上册_knowledge.json",
          "nonempty": true,
          "env_specific": true
        },
        {
          "name": "markdown_has_multiple_pages",
          "type": "file_contains",
          "path": "Review - 高等数学-第八版-上册/extracted_content.md",
          "contains": "[PAGE",
          "min_count": 2,
          "env_specific": true
        },
        {
          "name": "html_file_created",
          "type": "file_contains",
          "path": "Review - 高等数学-第八版-上册/Review - 高等数学-第八版-上册.html",
          "contains": "MathJax",
          "env_specific": true
        }
      ]
    },
    {
      "id": 3,
      "name": "html-interactivity",
      "prompt": "为 E:/sk2/docling_output/extracted_content.md 生成可交互的 HTML 复习文档，要有搜索和笔记功能",
      "expected_output": "生成包含搜索框、笔记输入框、进度追踪的 HTML 文件",
      "files": ["E:/sk2/docling_output/extracted_content.md"],
      "assertions": [
        {
          "name": "search_functionality",
          "type": "file_contains",
          "path": "Review - extracted_content/Review - extracted_content.html",
          "contains": "searchKnowledge",
          "env_specific": true
        },
        {
          "name": "note_functionality",
          "type": "file_contains",
          "path": "Review - extracted_content/Review - extracted_content.html",
          "contains": "saveNote",
          "env_specific": true
        },
        {
          "name": "progress_tracking",
          "type": "file_contains",
          "path": "Review - extracted_content/Review - extracted_content.html",
          "contains": "updateProgress",
          "env_specific": true
        },
        {
          "name": "theme_toggle",
          "type": "file_contains",
          "path": "Review - extracted_content/Review - extracted_content.html",
          "contains": "toggleTheme",
          "env_specific": true
        }
      ]
    },
    {
      "id": 4,
      "name": "docx-review",
      "prompt": "帮我复习这本 Word 讲义，文件在 test_data/sample.docx",
      "expected_output": "生成 Review - sample/ 目录，包含 extracted_content.md, knowledge.json, Review.html 文件",
      "files": ["test_data/sample.docx"],
      "assertions": [
        {
          "name": "output_directory_exists",
          "type": "dir_exists",
          "path": "Review - sample/"
        },
        {
          "name": "markdown_has_page_markers",
          "type": "file_contains",
          "path": "Review - sample/extracted_content.md",
          "contains": "[PAGE",
          "min_count": 1
        },
        {
          "name": "json_extractor_is_markitdown",
          "type": "json_field_equals",
          "path": "Review - sample/extracted_content.json",
          "field": "extractor",
          "equals": "markitdown"
        },
        {
          "name": "json_format_is_docx",
          "type": "json_field_equals",
          "path": "Review - sample/extracted_content.json",
          "field": "format",
          "equals": "docx"
        },
        {
          "name": "html_file_created",
          "type": "file_contains",
          "path": "Review - sample/Review - sample.html",
          "contains": "MathJax"
        }
      ]
    },
    {
      "id": 5,
      "name": "txt-gbk-review",
      "prompt": "整理 test_data/sample_gbk.txt 的知识点",
      "expected_output": "正确识别 GBK 编码，生成 Review 目录，无乱码，中文字符占比 > 30%",
      "files": ["test_data/sample_gbk.txt"],
      "assertions": [
        {
          "name": "output_directory_exists",
          "type": "dir_exists",
          "path": "Review - sample_gbk/"
        },
        {
          "name": "markdown_has_page_markers",
          "type": "file_contains",
          "path": "Review - sample_gbk/extracted_content.md",
          "contains": "[PAGE"
        },
        {
          "name": "json_format_is_txt",
          "type": "json_field_equals",
          "path": "Review - sample_gbk/extracted_content.json",
          "field": "format",
          "equals": "txt"
        },
        {
          "name": "json_encoding_contains_gb",
          "type": "file_contains",
          "path": "Review - sample_gbk/extracted_content.json",
          "contains": "gb"
        },
        {
          "name": "html_file_created",
          "type": "file_contains",
          "path": "Review - sample_gbk/Review - sample_gbk.html",
          "contains": "MathJax"
        }
      ]
    },
    {
      "id": 6,
      "name": "md-review",
      "prompt": "把 test_data/sample.md 做成复习网页",
      "expected_output": "生成 Review - sample/ 目录，保留原标题结构",
      "files": ["test_data/sample.md"],
      "assertions": [
        {
          "name": "output_directory_exists",
          "type": "dir_exists",
          "path": "Review - sample/"
        },
        {
          "name": "headings_preserved",
          "type": "file_contains",
          "path": "Review - sample/extracted_content.md",
          "contains": "## "
        },
        {
          "name": "page_markers_present",
          "type": "file_contains",
          "path": "Review - sample/extracted_content.md",
          "contains": "[PAGE"
        },
        {
          "name": "html_file_created",
          "type": "file_contains",
          "path": "Review - sample/Review - sample.html",
          "contains": "MathJax"
        }
      ]
    },
    {
      "id": 7,
      "name": "mixed-format-batch",
      "prompt": "帮我同时复习这两个文件：test_data/sample.docx 和 test_data/sample.md，合并成一个复习文档",
      "expected_output": "生成 Review - combined/ 目录，extracted_content.md 包含两个来源的合并内容，每个来源有 === 来源：xxx === 标注",
      "files": ["test_data/sample.docx", "test_data/sample.md"],
      "assertions": [
        {
          "name": "combined_directory_exists",
          "type": "dir_exists",
          "path": "Review - combined/"
        },
        {
          "name": "both_sources_present",
          "type": "file_contains",
          "path": "Review - combined/extracted_content.md",
          "contains": "=== 来源：",
          "min_count": 2
        },
        {
          "name": "page_markers_present",
          "type": "file_contains",
          "path": "Review - combined/extracted_content.md",
          "contains": "[PAGE"
        },
        {
          "name": "html_file_created",
          "type": "file_contains",
          "path": "Review - combined/Review - combined.html",
          "contains": "MathJax"
        }
      ]
    },
    {
      "id": 8,
      "name": "negative-novel-summary",
      "prompt": "帮我总结一下这本小说的主要情节，文件在 my_novel.txt",
      "expected_output": "skill 不应触发。小说不在适用场景（SKILL.md 明确说不适合纯文字书）。Claude 应直接对话回复总结，不生成 Review 目录",
      "files": [],
      "assertions": [
        {
          "name": "skill_not_triggered",
          "type": "no_dir_matching",
          "pattern": "Review - my_novel*"
        },
        {
          "name": "no_extracted_content",
          "type": "file_not_contains",
          "path": "Review - my_novel/extracted_content.md",
          "not_contains": "anything"
        },
        {
          "name": "no_html_generated",
          "type": "no_dir_matching",
          "pattern": "Review - my_novel*"
        }
      ]
    },
    {
      "id": 9,
      "name": "negative-pdf-parse-script",
      "prompt": "帮我写一个 Python 脚本，用 pypdf 解析 PDF 提取文字，不需要复习笔记",
      "expected_output": "skill 不应触发。用户要的是写代码脚本，不是复习教材。Claude 应直接帮写脚本，不调用 exam-review-helper",
      "files": [],
      "assertions": [
        {
          "name": "skill_not_triggered",
          "type": "no_dir_matching",
          "pattern": "Review - *"
        },
        {
          "name": "no_extracted_content",
          "type": "file_not_contains",
          "path": "extracted_content.md",
          "not_contains": "knowledge_points"
        },
        {
          "name": "no_knowledge_json",
          "type": "no_dir_matching",
          "pattern": "Review - *"
        }
      ]
    }
  ]
}
